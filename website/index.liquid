<script>
    // create a function to update the date and time
    function updateDateTime() {
        // create a new `Date` object
        const now = new Date();

        // get the current date and time as a string
        const fmt = Intl.DateTimeFormat('en-US', {
            timeZone: 'America/Los_Angeles',
            hour: "numeric",
            minute: "numeric",
            second: "numeric",
            hourCycle: "h12",
        });
        const currentDateTime = fmt.format(now);

        // update the `textContent` property of the `span` element with the `id` of `datetime`
        document.querySelector('#now').textContent = `It is ${fmt.format(now)} in Berkeley, CA`
    }

    // call the `updateDateTime` function every second
    setInterval(updateDateTime, 1000);
    updateDateTime();

    // last.fm widget stuff
    const loadData = async () => {
        const listening = document.getElementById("last-fm");
        const response = await fetch(`/.netlify/functions/last-fm`, {
            method: "GET",
        });
        const data = await response.json();

        listening.innerHTML = `Listening to <span class="text-keynote-600">${data.trackName}</span> by <span class="text-keynote-600">${data.artist}</span>`;
        // listening.href = data.url;
    };

    loadData();
</script>
